---
import "@fontsource-variable/montserrat";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description, noindex } = Astro.props;
const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const siteUrl = "https://www.ultramarinoselcalvo.com";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const defaultDescription = lang === "es"
  ? "Ultramarinos El Calvo, restaurante con Estrella Michelin del chef Borja García en Puerto Real, Cádiz. Conservas, salazones, chacinas y cocina tradicional andaluza."
  : "Ultramarinos El Calvo, Michelin Star restaurant by chef Borja García in Puerto Real, Cádiz. Traditional Andalusian cuisine with premium conservas, cured meats and seafood.";
const metaDescription = description || defaultDescription;
const pageTitle = title.includes("ULTRAMARINOS") ? title : `${title} | Ultramarinos El Calvo`;
const ogImage = `${siteUrl}/preview.webp`;

// Hreflang mappings for bilingual pages
const hreflangMap: Record<string, string> = {
  "/": "/en/",
  "/en/": "/",
  "/contacto/": "/en/contact/",
  "/en/contact/": "/contacto/",
  "/carta-mesa/": "/en/table-menu/",
  "/en/table-menu/": "/carta-mesa/",
  "/carta-barreo/": "/en/bar-menu/",
  "/en/bar-menu/": "/carta-barreo/",
};
const pathname = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
const alternatePath = hreflangMap[pathname];
const esPath = lang === "es" ? pathname : alternatePath;
const enPath = lang === "en" ? pathname : alternatePath;
---

<!doctype html>
<html lang={lang} class="font-sans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <link rel="icon" type="image/svg+xml" href="/icon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <meta
      name="keywords"
      content="Ultramarinos, El Calvo, Borja García, Estrella Michelin, Conservas, Salazones, Chacinas, Puerto Real, Cádiz"
    />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>

    <!-- Leaflet CSS -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />

    <!-- Open Graph / Facebook -->
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="ultramarinoselcalvo.com" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Hreflang for bilingual SEO -->
    {esPath && <link rel="alternate" hreflang="es" href={new URL(esPath, siteUrl).href} />}
    {enPath && <link rel="alternate" hreflang="en" href={new URL(enPath, siteUrl).href} />}
    {esPath && <link rel="alternate" hreflang="x-default" href={new URL(esPath, siteUrl).href} />}

    <!-- Restaurant Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Restaurant",
      "name": "Ultramarinos El Calvo",
      "image": `${siteUrl}/preview.webp`,
      "url": siteUrl,
      "telephone": "+34956992222",
      "email": "ultramarinoselcalvo@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle de la Plaza 149",
        "addressLocality": "Puerto Real",
        "addressRegion": "Cádiz",
        "postalCode": "11500",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 36.5283789,
        "longitude": -6.1921405
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "12:00",
          "closes": "16:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "21:00",
          "closes": "23:30"
        }
      ],
      "servesCuisine": ["Andalusian", "Spanish", "Mediterranean"],
      "priceRange": "€€€",
      "award": "Estrella Michelin",
      "starRating": {
        "@type": "Rating",
        "ratingValue": "1",
        "bestRating": "3",
        "ratingExplanation": "Michelin Star"
      },
      "founder": {
        "@type": "Person",
        "name": "Borja García Prieto",
        "jobTitle": "Chef"
      },
      "hasMenu": [
        {
          "@type": "Menu",
          "name": lang === "es" ? "Carta de Barreo" : "Bar Menu",
          "url": `${siteUrl}${lang === "es" ? "/carta-barreo" : "/en/bar-menu"}`
        },
        {
          "@type": "Menu",
          "name": lang === "es" ? "Carta de Mesa" : "Table Menu",
          "url": `${siteUrl}${lang === "es" ? "/carta-mesa" : "/en/table-menu"}`
        }
      ],
      "sameAs": [
        "https://www.instagram.com/ultramarinoselcalvo/"
      ],
      "acceptsReservations": "True"
    })} />
  </head>

  <body class="min-h-screen mx-auto antialiased">
    <slot />
  </body>
</html>
<style>
  html {
    font-family: "Montserrat Variable", sans-serif;
    overscroll-behavior: none;
  }
  body {
    overscroll-behavior: none;
  }
</style>
