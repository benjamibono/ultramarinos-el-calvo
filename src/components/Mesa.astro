---
import { Image } from "astro:assets";
import { t } from "../i18n/translations";
import { getTableMenuSections } from "../lib/cms";

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;
const i18n = t(lang);
const tableMenuSections = await getTableMenuSections(lang);
---

<section
  class="flex flex-col lg:flex-row relative z-10 h-auto mx-2 xs:mx-3 sm:mx-4 md:mx-6 lg:mx-8 my-4 sm:my-6 md:my-8"
>
  <div
    class="w-full lg:w-1/2 flex flex-col text-pretty px-2 xs:px-3 sm:px-4 md:px-6 lg:px-10"
  >
    <h2
      class="text-lg sm:text-xl md:text-2xl font-semibold text-center tracking-[0.35em]"
    >
      {i18n.tableMenu.title1}
    </h2>
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-center pb-1">
      {i18n.tableMenu.title2}
    </h2>
    <p class="border-b-2 border-black"></p>
    <div
      class="text-rotator text-xs sm:text-sm md:text-base font-semibold text-center tracking-[.25em] py-2 leading-relaxed"
    >
      {i18n.tableMenu.rotatingTexts.map((text: string) => (
        <span class="rotating-text">{text}</span>
      ))}
    </div>
    <div
      class="mt-4 text-xs font-medium sm:text-sm md:text-base tracking-[.25em] space-y-2"
    >
      {tableMenuSections.map((section: { title: string; items: string[] }) => (
        <>
          <h3
            class="text-left text-xs sm:text-sm md:text-base font-semibold tracking-[.25em] py-2 underline"
          >
            {section.title}
          </h3>
          <ul class="space-y-1 sm:space-y-2">
            {section.items.map((item: string) => (
              <li>{item}</li>
            ))}
          </ul>
        </>
      ))}
    </div>
  </div>
  <div class="w-full lg:w-1/2 hidden lg:block">
    <Image
      src="/mesa.webp"
      class="w-full h-full object-cover"
      alt={i18n.tableMenu.imgAlt}
      title={i18n.tableMenu.imgAlt}
      width={800}
      height={600}
      quality={85}
      sizes="(max-width: 1024px) 0, 800px"
    />
  </div>
</section>

<style>
  .text-rotator {
    position: relative;
    height: 40px;
    overflow: hidden;
  }

  .rotating-text {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    text-align: center;
    animation: rotateText 18s infinite linear;
    opacity: 0;
  }

  .rotating-text:nth-child(1) {
    animation-delay: 0s;
  }
  .rotating-text:nth-child(2) {
    animation-delay: 2s;
  }
  .rotating-text:nth-child(3) {
    animation-delay: 4s;
  }
  .rotating-text:nth-child(4) {
    animation-delay: 6s;
  }
  .rotating-text:nth-child(5) {
    animation-delay: 8s;
  }
  .rotating-text:nth-child(6) {
    animation-delay: 10s;
  }
  .rotating-text:nth-child(7) {
    animation-delay: 14s;
  }

  @keyframes rotateText {
    0% {
      top: 100%;
      opacity: 0;
    }
    10%,
    15% {
      top: 0;
      opacity: 1;
    }
    25% {
      top: -100%;
      opacity: 0;
    }
    100% {
      top: -100%;
      opacity: 0;
    }
  }
</style>
