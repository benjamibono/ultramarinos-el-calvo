---
import { Image } from "astro:assets";
import { t } from "../i18n/translations";

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;
const i18n = t(lang);
---

<section class="bg-[#fafaf2]">
  <div
    class="w-full flex min-h-[1800px] sm:min-h-[2000px] lg:min-h-[2200px] xxl:min-h-[2600px] xxxl:min-h-[3200px] max-w-screen-xxl xxl:max-w-[2000px] xxxl:max-w-[3000px] sm:mx-auto relative z-10 p-4 sm:p-6 lg:p-8 xxl:p-12 xxxl:p-20 overflow-hidden bg-[#fafaf2] pb-6 sm:pb-10"
  >
    <div
      class="grid grid-cols-1 sm:grid-cols-2 gap-2 sm:gap-4 lg:gap-6 xxl:gap-8 xxxl:gap-16 h-auto sm:min-h-[2000px] lg:min-h-[2200px] xxl:min-h-[2600px] xxxl:min-h-[3200px]"
    >
      <div
        class="row-span-1 flex items-center justify-center p-2 sm:p-4 xxl:p-6 xxxl:p-12 h-full"
      >
        <Image
          src="/close-up.webp"
          class="object-cover rounded-lg w-full h-full xxxl:max-h-[1200px]"
          alt={i18n.description.section1.imgAlt}
          title={i18n.description.section1.imgAlt}
          width={600}
          height={400}
          quality={75}
          fetchpriority="high"
          loading="eager"
          sizes="(max-width: 640px) 100vw, (max-width: 2560px) 800px, (max-width: 3840px) 1600px, 2000px"
        />
      </div>
      <div
        class="row-span-1 flex flex-col justify-center px-4 sm:px-8 md:px-12 lg:px-16 xxl:px-20 xxxl:px-32 py-4 sm:py-6 lg:py-8 xxl:py-10 xxxl:py-16"
      >
        <h2
          class="mt-2 sm:mt-4 font-semibold text-base sm:text-xl md:text-2xl lg:text-3xl xxl:text-4xl xxxl:text-6xl overflow-hidden"
        >
          {i18n.description.section1.title}
        </h2>
        <p
          class="mt-2 sm:mt-4 text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl xxl:text-3xl xxxl:text-5xl overflow-hidden text-balance"
        >
          <Fragment set:html={i18n.description.section1.text} />
        </p>
      </div>
      <div
        class="sm:hidden row-span-1 flex items-center justify-center p-2 h-full"
      >
        <Image
          src="/salon-hzt.webp"
          class="object-cover rounded-lg w-full h-full xxxl:max-h-[1200px]"
          alt={i18n.description.section2.imgAlt}
          title={i18n.description.section2.imgAlt}
          width={600}
          height={400}
          quality={75}
          sizes="(max-width: 640px) 100vw, (max-width: 2560px) 800px, (max-width: 3840px) 1600px, 2000px"
        />
      </div>
      <div
        class="row-span-1 flex flex-col justify-center px-4 sm:px-8 md:px-12 lg:px-16 xxl:px-20 xxxl:px-32 py-4 sm:py-6 lg:py-8 xxl:py-10 xxxl:py-16"
      >
        <h2
          class="mt-2 sm:mt-4 font-semibold text-base sm:text-xl md:text-2xl lg:text-3xl xxl:text-4xl xxxl:text-6xl overflow-hidden"
        >
          {i18n.description.section2.title}
        </h2>
        <p
          class="mt-2 sm:mt-4 text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl xxl:text-3xl xxxl:text-5xl overflow-hidden text-balance"
        >
          <Fragment set:html={i18n.description.section2.text} />
        </p>
      </div>
      <div
        class="hidden row-span-1 sm:flex items-center justify-center p-2 sm:p-4 xxl:p-6 xxxl:p-12 h-full"
      >
        <Image
          src="/salon-hzt.webp"
          class="object-cover rounded-lg w-full h-full xxxl:max-h-[1200px]"
          alt={i18n.description.section2.imgAlt}
          title={i18n.description.section2.imgAlt}
          width={600}
          height={400}
          quality={75}
          sizes="(max-width: 640px) 100vw, (max-width: 2560px) 800px, (max-width: 3840px) 1600px, 2000px"
        />
      </div>
      <div
        class="row-span-1 flex items-center justify-center p-2 sm:p-4 xxl:p-6 xxxl:p-12 h-full"
      >
        <Image
          src="/mesa-hzt.webp"
          class="object-cover rounded-lg w-full h-full xxxl:max-h-[1200px]"
          alt={i18n.description.section3.imgAlt}
          title={i18n.description.section3.imgAlt}
          width={600}
          height={400}
          quality={75}
          sizes="(max-width: 640px) 100vw, (max-width: 2560px) 800px, (max-width: 3840px) 1600px, 2000px"
        />
      </div>
      <div
        class="row-span-1 flex flex-col justify-center px-4 sm:px-8 md:px-12 lg:px-16 xxl:px-20 xxxl:px-32 py-4 sm:py-6 lg:py-8 xxl:py-10 xxxl:py-16"
      >
        <h2
          class="mt-2 sm:mt-4 font-semibold text-base sm:text-xl md:text-2xl lg:text-3xl xxl:text-4xl xxxl:text-6xl overflow-hidden"
        >
          {i18n.description.section3.title}
        </h2>
        <p
          class="mt-2 sm:mt-4 text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl xxl:text-3xl xxxl:text-5xl text-balance"
        >
          <Fragment set:html={i18n.description.section3.text} />
        </p>
      </div>
    </div>
  </div>
</section>
